{
  "_exportVersion": 2,
  "template": {
    "id": "republika-logo",
    "name": "Republika Logo",
    "type": "IMAGE",
    "version": 1,
    "html_template": "<div class=\"rep-logo-box\">\n    <img class=\"rep-logo-img\" src=\"{{LOGO_URL}}\" alt=\"Logo\" />\n</div>",
    "css_template": "#{{ID}} .rep-logo-box {\n    z-index: 50;\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: {{#if LOGO_WIDTH}}{{LOGO_WIDTH}}px{{else}}150px{{/if}};\n    height: {{#if LOGO_HEIGHT}}{{LOGO_HEIGHT}}px{{else}}80px{{/if}};\n    background: {{#if TRANSPARENT}}transparent{{else}}{{PRIMARY_BG}}{{/if}};\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 10px;\n    box-sizing: border-box;\n    box-shadow: {{#if TRANSPARENT}}none{{else}}{{BOX_SHADOW}}{{/if}};\n    opacity: 0;\n    transform-origin: left center;\n    transform: {{ANIMATION_IN_TRANSFORM}};\n    transition: all {{ANIMATION_DURATION}}s {{ANIMATION_EASE}};\n    border-right: {{#if TRANSPARENT}}none{{else}}2px solid rgba(255,255,255,0.1){{/if}};\n}\n#{{ID}} .rep-logo-img {\n    max-width: 90%;\n    max-height: 90%;\n    object-fit: contain;\n    filter: {{#if TRANSPARENT}}none{{else}}drop-shadow(0 2px 4px rgba(0,0,0,0.5)){{/if}};\n}",
    "js_template": "(() => {\n    const root = document.getElementById(\"{{ID}}\");\n    const container = root.querySelector(\".rep-logo-box\");\n    root.__slt_show = () => {\n        return GSAPFX.standardIn(container, {{{ANIMATION_IN_JSON}}});\n    };\n    root.__slt_hide = () => {\n        return GSAPFX.standardOut(container, {{{ANIMATION_OUT_JSON}}});\n    };\n})();",
    "defaultFields": {
      "logoUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/e/e4/TV_Republika_logo_2024.svg/200px-TV_Republika_logo_2024.svg.png",
      "LOGO_URL": ""
    },
    "defaultLayout": {
      "x": 96,
      "y": 910
    },
    "ocgInputs": [
      {
        "id": "LOGO_URL",
        "label": "URL Grafiki / Logo",
        "default": "",
        "type": "text"
      }
    ]
  },
