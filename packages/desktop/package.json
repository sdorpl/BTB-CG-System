{
  "name": "@btb-cg/desktop",
  "version": "1.1.0",
  "description": "BTB CG System — Desktop application",
  "author": {
    "name": "BTB",
    "email": "btb@cgmaster.local"
  },
  "homepage": "https://github.com/sdorpl/BTB-CG-System",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "prebuild": "node prebuild-server.js",
    "rebuild": "electron-builder install-app-deps",
    "dist:win": "npm run prebuild && electron-builder --win",
    "dist:mac": "npm run prebuild && electron-builder --mac",
    "dist:mac:arm": "npm run prebuild && electron-builder --mac --arm64",
    "dist:linux": "npm run prebuild && electron-builder --linux",
    "dist:all": "npm run prebuild && electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.btb.cgsystem",
    "productName": "BTB CG System",
    "asar": true,
    "asarUnpack": ["**/node_modules/better-sqlite3/**"],
    "electronVersion": "41.1.0",
    "afterPack": "./electron-builder-hooks.js",
    "files": [
      "main.js",
      "preload.js",
      "preload-connect.js",
      "connect.html",
      "splash.html",
      "package.json",
      "icon.svg",
      "icon.png",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "../server/",
        "to": "server/",
        "filter": [
          "**/*",
          "!uploads/**",
          "!database.sqlite*"
        ]
      },
      {
        "from": "../client/",
        "to": "client/",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": "../server/uploads/",
        "to": "uploads/",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "icon.ico",
      "target": ["nsis", "portable"]
    },
    "linux": {
      "icon": "icon.png",
      "target": ["AppImage", "deb"],
      "artifactName": "BTB-CG-System-${version}-${arch}.${ext}"
    },
    "directories": {
      "output": "../../dist"
    }
  }
}
