{
  "name": "@btb-cg/desktop",
  "version": "1.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "prebuild": "cd ../server && npm install --install-strategy=nested --omit=dev --ignore-scripts && npm rebuild better-sqlite3",
    "rebuild": "electron-builder install-app-deps",
    "dist:win": "npm run prebuild && electron-builder --win",
    "dist:mac": "npm run prebuild && electron-builder --mac",
    "dist:mac:arm": "npm run prebuild && electron-builder --mac --arm64",
    "dist:linux": "npm run prebuild && electron-builder --linux",
    "dist:all": "npm run prebuild && electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.btb.cgsystem",
    "productName": "BTB CG System",
    "asar": false,
    "afterPack": "./electron-builder-hooks.js",
    "files": [
      "main.js",
      "splash.html",
      "package.json",
      "icon.svg",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../server/",
        "to": "server/",
        "filter": [
          "**/*",
          "!uploads/**"
        ]
      },
      {
        "from": "../client/",
        "to": "client/",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": "../server/uploads/",
        "to": "uploads/",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "icon": "icon.png",
      "target": ["AppImage", "deb"]
    },
    "directories": {
      "output": "../../dist"
    }
  }
}
