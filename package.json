{
  "name": "btb-cg-system",
  "version": "1.1.0",
  "private": true,
  "description": "BTB CG System — Profesjonalny system sterowania grafiką emisyjną z renderowaniem w czasie rzeczywistym przez Socket.io.",
  "workspaces": [
    "packages/client",
    "packages/server",
    "packages/desktop"
  ],
  "scripts": {
    "start": "npm run start --workspace=packages/server",
    "dev": "npm run dev --workspace=packages/server",
    "start:electron": "npm run start --workspace=packages/desktop",
    "build:css": "npm run build:css --workspace=packages/client",
    "dev:css": "npm run dev:css --workspace=packages/client",
    "build:vendor": "npm run build:vendor --workspace=packages/client",
    "build:client": "npm run build --workspace=packages/client",
    "init-db": "npm run init-db --workspace=packages/server",
    "dist:win": "npm run dist:win --workspace=packages/desktop",
    "dist:mac": "npm run dist:mac --workspace=packages/desktop",
    "dist:linux": "npm run dist:linux --workspace=packages/desktop",
    "dist:all": "npm run dist:all --workspace=packages/desktop"
  },
  "keywords": [],
  "author": {
    "name": "BTB",
    "email": "btb@cgmaster.local"
  },
  "license": "ISC"
}
