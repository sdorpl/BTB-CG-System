{
  "name": "newera",
  "version": "1.0.0",
  "description": "CG Master — Professional broadcast graphics control system with real-time rendering via Socket.io.",
  "main": "main.js",
  "scripts": {
    "start:electron": "electron . --no-sandbox",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:mac:arm": "electron-builder --mac --arm64",
    "dist:mac:universal": "electron-builder --mac --universal",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder -mwl",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "init-db": "node init-db.js",
    "build:css": "npx tailwindcss -i ./input.css -o ./tailwind.css",
    "dev": "npx tailwindcss -i ./input.css -o ./tailwind.css --watch & node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "gsap": "^3.14.2",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.0.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  },
  "build": {
    "appId": "com.btb.cgmaster",
    "productName": "CG Master",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "directories": {
      "output": "dist"
    }
  }
}
